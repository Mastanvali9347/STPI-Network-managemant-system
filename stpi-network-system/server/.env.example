# Use 5001 — port 5000 is often taken by PostgreSQL on Windows
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/stpi_network
JWT_SECRET=a-string-secret-at-least-256-bits-long
# Frontend origin(s) allowed by CORS.
# Accepts comma-separated origins. Scheme may be omitted for localhost.
# Example: CLIENT_URL=http://localhost:5173,https://stpi-network-managemant-system.vercel.app
# Alternative alias: CLIENT_URLS=https://stpi-network-managemant-system.vercel.app
CLIENT_URL=http://localhost:5173,https://stpi-network-managemant-system.vercel.app
NODE_ENV=development
# 32+ char secret for AES-256 WiFi password vault (production)
WIFI_VAULT_KEY=change-this-to-a-long-random-string-in-production
